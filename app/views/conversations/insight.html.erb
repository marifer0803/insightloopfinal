<% sentiment_colors = { "positivo" => "badge-soft-success", "neutro" => "badge-soft-gray", "frustrado" => "badge-soft-warn", "crítico" => "badge-soft-danger" } %>

<div class="conversation-show">

  <div class="conversation-show__header">
    <h1 class="conversation-show__title"><%= @conversation.classification&.tag || "Aguardando classificação" %></h1>
  </div>

  <div class="conversation-show__meta">
    <% sentiment = @conversation.sentiment_label.to_s %>
    <% if sentiment.present? %>
      <span class="badge <%= sentiment_colors[sentiment] || 'badge-soft-gray' %>">
        <%= sentiment.capitalize %>
      </span>
    <% end %>

    <% if @conversation.channel.present? %>
      <span class="meta-item">
        <strong>Canal:</strong> <%= @conversation.channel %>
      </span>
    <% end %>

    <span class="meta-item">
      <strong>Data:</strong> <%= @conversation.occurred_on.strftime("%d/%m/%Y") %>
    </span>
  </div>

  <% if @conversation.customer.present? %>
    <div class="conversation-show__meta" style="margin-top: 0.5rem;">
      <span class="meta-item">
        <strong>Cliente:</strong> <%= @conversation.customer.name %>
      </span>

      <% if @conversation.customer.plan.present? %>
        <span class="meta-item">
          <strong>Plano:</strong> <%= @conversation.customer.plan %>
        </span>
      <% end %>

      <% if @conversation.customer.mrr.present? %>
        <span class="meta-item">
          <strong>MRR:</strong> R$ <%= number_with_delimiter(@conversation.customer.mrr.to_i) %>
        </span>
      <% end %>
    </div>
  <% end %>

  <div class="conversation-thread">
    <h2>Conversa</h2>

    <% @conversation.content.to_s.lines.each do |line| %>
      <% if line.start_with?("[Customer]:") %>
        <div class="message message--customer">
          <span class="message__author">Cliente</span>
          <p><%= line.gsub("[Customer]:", "").strip %></p>
        </div>

      <% elsif line.start_with?("[Support Agent]:") %>
        <div class="message message--support">
          <span class="message__author">Suporte</span>
          <p><%= line.gsub("[Support Agent]:", "").strip %></p>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<%= link_to insight_list_conversations_path, class: "strategic-plan__back" do %>
  <i class="fa-solid fa-arrow-left-long"></i>
<% end %>
