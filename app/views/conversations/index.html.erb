<div class="conversations-page">
  <%= link_to dashboard_path, class: "back-link" do %>
    <i class="fa-solid fa-arrow-left-long"></i>
  <% end %>
  <h1 class="conversations-title">Todas as Conversas</h1>

  <% sentiment_colors = { "positivo" => "badge-soft-success", "neutro" => "badge-soft-gray", "frustrado" => "badge-soft-warn", "crítico" => "badge-soft-danger" } %>

  <% @conversations.each do |conversation| %>
    <div class="conversation-item">

      <!-- LEFT -->
      <div class="conversation-left">
        <div class="conversation-avatar">
          <%= conversation.customer&.name&.first || "?" %>
        </div>

        <div class="conversation-content">

          <p class="conversation-name">
            <%= conversation.customer&.name.presence || "Cliente não identificado" %>

            <% sentiment = conversation.sentiment_label.to_s %>
            <% if sentiment.present? %>
              <span class="badge <%= sentiment_colors[sentiment] || 'badge-soft-gray' %>">
                <%= sentiment.capitalize %>
              </span>
            <% end %>
          </p>

          <p class="conversation-subtitle">
            <% if conversation.classification&.tag.present? %>
              <span class="badge badge-soft-gray"><%= conversation.classification.tag %></span>
            <% end %>
            <% if conversation.channel.present? %>
              <span class="text-muted"><%= conversation.channel %></span>
            <% end %>
            <span class="text-muted"><%= conversation.occurred_on.strftime("%d/%m/%Y") %></span>
          </p>

          <p class="conversation-preview">
            <%= conversation.content.to_s.truncate(100) %>
          </p>

        </div>
      </div>

      <!-- RIGHT -->
      <div class="conversation-right">
        <%= link_to conversation_path(conversation),
              class: "conversation-arrow" do %>
         <i class="fa-solid fa-arrow-right-long"></i>
        <% end %>
      </div>

    </div>
  <% end %>

</div>
