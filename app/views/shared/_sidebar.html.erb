<aside class="sidebar" aria-label="Main navigation" role="navigation">
  <div class="brand">
    <div class="brand-text">
      <%= link_to home_path do %>
        <h2>InsightLoop</h2>
      <% end %>
    </div>
  </div>

  <div class="section">
    <h4 class="section-title">Menu</h4>

    <ul class="nav-list">
      <li class="nav-item <%= 'active' if current_page?(root_path) || current_page?(dashboard_path) %>">
        <%= link_to root_path do %>
          <span class="nav-icon"><i class="fa fa-th-large" aria-hidden="true"></i></span>
          <span class="nav-label">Dashboard</span>
        <% end %>
      </li>

      <li class="nav-item <%= 'active' if current_page?(conversations_path) %>">
        <%= link_to conversations_path do %>
          <span class="nav-icon"><i class="fa fa-comments" aria-hidden="true"></i></span>
          <span class="nav-label">Conversas</span>
        <% end %>
      </li>

      <li class="nav-item <%= 'active' if current_page?(classifications_path) || request.path.start_with?('/classifications') %>">
        <%= link_to classifications_path do %>
          <span class="nav-icon"><i class="fa fa-chart-bar" aria-hidden="true"></i></span>
          <span class="nav-label">Análises</span>
        <% end %>
      </li>

      <li class="nav-item <%= 'active' if request.path.start_with?('/chats') %>">
        <%= link_to chats_path, data: { turbo_method: :post } do %>
          <span class="nav-icon"><i class="fa fa-robot" aria-hidden="true"></i></span>
          <span class="nav-label">Chat</span>
        <% end %>
      </li>
    </ul>
  </div>
</aside>
