<div class="chat-show-page">

  <div class="card border-0 shadow-sm mb-3 chat-header-card">
    <div class="card-body">
      <h1 class="h4 mb-1" id="chat_title">
        <%= @chat.title.presence || "Untitled chat" %>
      </h1>
      <p class="text-muted small mb-0">
        Insight Loop · AI Assistant
      </p>
    </div>
  </div>

  <%= turbo_frame_tag :insight_assistant do %>
    <div class="ai-widget__body" data-ai-chat-target="messages">
      <div class="ai-bubble ai-bubble--assistant">
        Oi! Pergunte sobre volumes, tendências ou causas raiz.
      </div>

      <%= render "messages/messages", messages: @chat.messages %>
    </div>
    <%= render "messages/form", chat: @chat, message: @message %>
  <% end %>
</div>
