<div class="page-container">
  <h1 class="page-title">Análises</h1>
  <p class="page-subtitle">Visualize métricas e tendências do atendimento ao cliente</p>

  <!-- KPI Cards -->
  <section aria-label="KPIs" class="kpi-grid" role="region">
    <div class="kpi-card">
      <p class="kpi-label">Total de Conversas</p>
      <p class="kpi-value"><%= @total_conversations %></p>
    </div>

    <div class="kpi-card">
      <p class="kpi-label">Sentimento Médio</p>
      <p class="kpi-value"><%= @avg_sentiment %> / 5.0</p>
    </div>

    <div class="kpi-card">
      <p class="kpi-label">Receita em Risco</p>
      <p class="kpi-value">R$ <%= number_with_delimiter(@revenue_at_risk.to_i) %></p>
    </div>

    <div class="kpi-card">
      <p class="kpi-label">Receita Perdida</p>
      <p class="kpi-value">R$ <%= number_with_delimiter(@revenue_lost.to_i) %></p>
    </div>
  </section>

  <!-- Pareto / 80-20 analysis -->
  <section class="section-card" aria-labelledby="pareto-title">
    <h2 id="pareto-title">Análise de Foco 80/20 (Princípio de Pareto)</h2>
    <p class="muted">Identifique os poucos problemas (20%) que geram a maior parte do volume (80%)</p>

    <% if @pareto.any? %>
      <div class="pareto-callout">
        <p class="pareto-callout__title">
          <strong>Insight:</strong>
          Focar nos seguintes problemas resolverá
          <strong><%= @pareto.last.cum_pct.to_i %>%</strong> do volume total
        </p>

        <ul class="pareto-list">
          <% @pareto.each do |item| %>
            <li class="pareto-list__item">
              <strong><%= item.tag %></strong>:
              <%= item.pct.to_i %>% do volume total
              <span class="muted">(<%= item.cum_pct.to_i %>% cumulativo)</span>
            </li>
          <% end %>
        </ul>
      </div>

      <div id="classificationChart" class="chart-wrap">
        <%= render "shared/charts_paretto" %>
      </div>
    <% else %>
      <p class="text-muted">Nenhum dado disponível para análise de Pareto.</p>
    <% end %>
  </section>

  <!-- Classification table -->
  <section class="section-card" aria-labelledby="classification-table-title">
    <h3 id="classification-table-title">Classificações por Impacto</h3>
    <p class="muted">Ordenadas por Priority Score (composição de volume, sentimento, churn e receita)</p>

    <% if @classification_rows.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Tag</th>
              <th>Volume</th>
              <th>Sentimento Médio</th>
              <th>Churn Rate</th>
              <th>Receita Perdida</th>
              <th>Priority Score</th>
            </tr>
          </thead>
          <tbody>
            <% @classification_rows.each do |row| %>
              <% highlight = row.avg_sentiment >= 4 || row.churn_rate >= 30 %>
              <tr style="<%= 'background-color: #fff0f0; border-left: 3px solid #dc3545;' if highlight %>">
                <td>
                  <%= link_to row.tag, classification_path(row.id) %>
                </td>
                <td><%= row.volume %></td>
                <td>
                  <span class="<%= 'text-danger fw-bold' if row.avg_sentiment >= 4 %>">
                    <%= row.avg_sentiment %>
                  </span>
                </td>
                <td>
                  <span class="<%= 'text-danger fw-bold' if row.churn_rate >= 30 %>">
                    <%= row.churn_rate %>%
                  </span>
                </td>
                <td>R$ <%= number_with_delimiter(row.revenue_lost.to_i) %></td>
                <td><strong><%= row.priority_score %></strong></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted">Nenhuma classificação com conversas encontrada.</p>
    <% end %>
  </section>

  <!-- Top issues list -->
  <section class="section-card problems-section" aria-labelledby="top-issues-title">
    <h3 id="top-issues-title" class="problems-section__title">Principais Problemas</h3>
    <p class="problems-section__subtitle">Tópicos em alta que precisam de atenção</p>

    <div class="problems-list" role="list">
      <% @pareto.each_with_index do |item, i| %>
        <%= render partial: "shared/trend_card", locals: { item: item, index: i + 1 } %>
      <% end %>
    </div>
  </section>

  <div class="page-footer">
    <%= link_to root_path, class: "strategic-plan__back" do %>
      <i class="fa-solid fa-arrow-left-long"></i>
    <% end %>
  </div>
</div>
