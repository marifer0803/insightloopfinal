<!doctype html>
<html lang="pt-BR">
<head>
<!-- Basic document metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>InsightLoop — Customer Success Intelligence</title>
<meta name="description" content="Plataforma B2B SaaS para E-commerce Customer Success — Análise de tickets e automação com IA" />
<meta name="turbo-cache-control" content="no-cache" />

<!-- Fonts / CSS (replace with your toolchain or Tailwind build) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
<!-- TODO: replace with your app.css or Tailwind output -->
<link rel="stylesheet" href="/assets/styles.css" />


<!-- Open Graph (kept minimal) -->
<meta property="og:title" content="InsightLoop - Customer Success Intelligence" />
<meta property="og:description" content="Análises e automação para atendimento ao cliente de e-commerce" />

<!-- JS entry (defer) -->
<script defer src="/assets/app.js"></script>

</head>

<!-- BODY STARTS -->
<body>

<div id="app" class="app">

<!-- MAIN: header + content -->
<main class="content" id="main-content">
  <div class="page-container">
  <h1 class="page-title">Análises</h1>
  <p class="page-subtitle">Visualize métricas e tendências do atendimento ao cliente</p>

  <!-- KPI Cards -->
  <section aria-label="KPIs" class="kpi-grid" role="region">
    <div class="kpi-card">
      <p class="kpi-label">Volume Total</p>
      <p class="kpi-value"><%= Conversation.count %></p>
      <p class="kpi-delta kpi-delta--up">+12% vs. semana anterior</p>
    </div>

    <div class="kpi-card">
      <p class="kpi-label">Taxa de Resolução</p>
      <p class="kpi-value">88.5%</p>
      <p class="kpi-delta kpi-delta--up">+3.2% vs. semana anterior</p>
    </div>

    <div class="kpi-card">
      <p class="kpi-label">Tempo Médio</p>
      <p class="kpi-value">8.2 min</p>
      <p class="kpi-delta kpi-delta--down">+1.5 min vs. semana anterior</p>
    </div>

    <div class="kpi-card">
      <p class="kpi-label">Satisfação</p>
      <p class="kpi-value">4.6 / 5.0</p>
      <p class="kpi-delta kpi-delta--up">+0.2 vs. semana anterior</p>
    </div>
  </section>

  <!-- Pareto / 80-20 analysis -->
  <section class="section-card" aria-labelledby="pareto-title">
    <h2 id="pareto-title">Análise de Foco 80/20 (Princípio de Pareto)</h2>
    <p class="muted">Priorização por score composto: churn rate (40%) + receita perdida (30%) + sentimento (30%)</p>

    <div class="pareto-callout">
      <p class="pareto-callout__title">
        <strong>💡 Insight:</strong>
        Focar nos seguintes problemas resolverá
        <strong><%= @pareto.last&.dig(:cum_pct) || 0 %>%</strong> do volume total
      </p>

      <ul class="pareto-list">
        <% @pareto.each do |item| %>
          <li class="pareto-list__item">
            <strong><%= item[:tag] %></strong>:
            <%= item[:pct] %>% do volume total
            <span class="muted">(<%= item[:cum_pct] %>% cumulativo)</span>
            — Churn: <%= item[:churn_rate] %>%
            | Receita perdida: R$ <%= number_with_delimiter(item[:revenue_lost], delimiter: ".") %>
          </li>
        <% end %>
      </ul>
    </div>

    <div id="classificationChart" class="chart-wrap">
      <%= render "shared/charts_paretto" %>
    </div>
  </section>

  <!-- Financial Impact Table -->
  <section class="section-card" aria-labelledby="financial-impact-title">
    <h3 id="financial-impact-title">Impacto Financeiro por Classificação</h3>
    <p class="muted">Classificações ordenadas por score de prioridade composto</p>

    <div style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
        <thead>
          <tr style="border-bottom: 2px solid #e2e8f0; text-align: left;">
            <th style="padding: 12px 8px;">#</th>
            <th style="padding: 12px 8px;">Classificação</th>
            <th style="padding: 12px 8px;">Volume</th>
            <th style="padding: 12px 8px;">Churn Count</th>
            <th style="padding: 12px 8px;">Churn Rate</th>
            <th style="padding: 12px 8px;">Receita Perdida</th>
            <th style="padding: 12px 8px;">Receita em Risco</th>
            <th style="padding: 12px 8px;">Sentimento Médio</th>
            <th style="padding: 12px 8px;">Priority Score</th>
          </tr>
        </thead>
        <tbody>
          <% @pareto.each_with_index do |item, i| %>
            <% is_critical = item[:avg_sentiment] >= 4 || item[:churn_rate] >= 30 %>
            <tr style="border-bottom: 1px solid #e2e8f0; <%= 'background-color: #fff5f5;' if is_critical %>">
              <td style="padding: 10px 8px;"><%= i + 1 %></td>
              <td style="padding: 10px 8px;">
                <% classification = Classification.find_by(tag: item[:tag]) %>
                <% if classification %>
                  <%= link_to item[:tag], classification_path(classification), style: "font-weight: 600; color: #2d3748; text-decoration: none;" %>
                <% else %>
                  <strong><%= item[:tag] %></strong>
                <% end %>
                <% if is_critical %>
                  <span style="background: #e53e3e; color: white; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem; margin-left: 8px;">CRÍTICO</span>
                <% end %>
              </td>
              <td style="padding: 10px 8px;"><%= item[:count] %></td>
              <td style="padding: 10px 8px;"><%= item[:churn_count] %></td>
              <td style="padding: 10px 8px; <%= 'color: #e53e3e; font-weight: 700;' if item[:churn_rate] >= 30 %>">
                <%= item[:churn_rate] %>%
              </td>
              <td style="padding: 10px 8px; color: #e53e3e; font-weight: 600;">
                R$ <%= number_with_delimiter(item[:revenue_lost].round(0), delimiter: ".") %>
              </td>
              <td style="padding: 10px 8px; color: #dd6b20; font-weight: 600;">
                R$ <%= number_with_delimiter(item[:revenue_at_risk].round(0), delimiter: ".") %>
              </td>
              <td style="padding: 10px 8px; <%= 'color: #e53e3e; font-weight: 700;' if item[:avg_sentiment] >= 4 %>">
                <%= item[:avg_sentiment] %> / 5.0
              </td>
              <td style="padding: 10px 8px; font-weight: 700;">
                <%= (item[:priority_score] * 100).round(1) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Top issues list -->
  <section class="section-card problems-section" aria-labelledby="top-issues-title">
    <h3 id="top-issues-title" class="problems-section__title">Principais Problemas</h3>
    <p class="problems-section__subtitle">Tópicos priorizados por impacto financeiro e churn</p>

    <div class="problems-list" role="list">
      <% @pareto.each_with_index do |item, i| %>
        <%= render partial: "shared/trend_card_hash", locals: { item: item, index: i + 1 } %>
      <% end %>
    </div>
  </section>

   <div class="page-footer">
  <!--   <%= link_to "⬅", root_path, class: "back-link" %>-->
    <%= link_to root_path, class: "strategic-plan__back" do %>
      <i class="fa-solid fa-arrow-left-long"></i>
    <% end %>
  </div>
  </div>
</main>
</div>
</div>


</body>
</html>
