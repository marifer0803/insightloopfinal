<div class="dashboard-page">
  <header class="dashboard-header">
    <div>
      <h1 class="dashboard-header__title"></h1>
      <p class="dashboard-header__subtitle"></p>
    </div>

    <div class="dashboard-header__date-filter">
      <div class="date-filter__dropdown" id="dateFilterDropdown">
        <button
          data-range="7d"
          class="<%= 'active' if @active_preset == :last_7_days %>">
          Últimos 7 dias
        </button>

        <button
          data-range="1m"
          class="<%= 'active' if @active_preset == :last_month %>">
          Último mês
        </button>

        <button
          data-range="3m"
          class="<%= 'active' if @active_preset == :last_quarter %>">
          Último quarter
        </button>
        <div class="date-filter__divider"></div>

        <div class="date-filter__custom">
          <label>
            Período
            <input
              type="text"
              id="dateRange"
              class="date-input"
              placeholder="Selecione um período"
              autocomplete="off"
              value="<%= @start_date && @end_date ? "#{@start_date} → #{@end_date}" : "" %>">
          </label>

          <input type="hidden" name="start_date" id="startDate" value="<%= @start_date %>">
          <input type="hidden" name="end_date" id="endDate" value="<%= @end_date %>">
        </div>
      </div>
    </div>

    <%= javascript_include_tag "date_range_store", defer: true %>
    <%= javascript_include_tag "date_filter", defer: true %>
    <%= javascript_include_tag "dashboard", defer: true %>
  </header>

  <!-- KPI Cards -->
  <section class="dashboard-kpi-grid">
    <!-- Card 1: Total Conversations -->
    <article class="kpi-card kpi-card--questions">
      <div class="kpi-card__header">
        <div class="kpi-card__title">
          <i class="kpi-card__icon fa-solid fa-comments"></i>
          Total de Conversas
        </div>
      </div>

      <div class="kpi-card__body">
        <div>
          <p class="kpi-card__value"><%= @total_conversations %></p>
          <p class="kpi-card__hint">no período selecionado</p>
        </div>

        <%= link_to "Ver Conversas",
            conversations_path,
            class: "kpi-card__button kpi-card__button--questions" %>
      </div>
    </article>

    <!-- Card 2: Critical Sentiment -->
    <article class="kpi-card kpi-card--complaints">
      <div class="kpi-card__header">
        <div class="kpi-card__title">
          <i class="kpi-card__icon fa-solid fa-circle-exclamation"></i>
          Sentimento Crítico
        </div>
      </div>

      <div class="kpi-card__body">
        <div>
          <p class="kpi-card__value"><%= @critical_sentiment_count %></p>
          <p class="kpi-card__hint">conversas críticas ou frustradas</p>
        </div>

        <%= link_to "Análise 80/20",
            classifications_path,
            class: "kpi-card__button kpi-card__button--complaints" %>
      </div>
    </article>

    <!-- Card 3: Revenue at Risk -->
    <article class="kpi-card kpi-card--product">
      <div class="kpi-card__header">
        <div class="kpi-card__title">
          <i class="kpi-card__icon fa-solid fa-triangle-exclamation"></i>
          Receita em Risco
        </div>
      </div>

      <div class="kpi-card__body">
        <div>
          <p class="kpi-card__value">R$ <%= number_with_delimiter(@revenue_at_risk.to_i) %></p>
          <p class="kpi-card__hint">MRR de clientes at risk no período</p>
        </div>

        <%= link_to "Ver Análises",
            classifications_path,
            class: "kpi-card__button kpi-card__button--product" %>
      </div>
    </article>
  </section>

  <!-- Top 3 Problems by Impact -->
  <% if @top_problems.any? %>
    <section class="panel">
      <div class="panel__header">
        <h2 class="panel__title">Top 3 Problemas por Impacto</h2>
        <p class="panel__subtitle">Classificações com maior priority score no período</p>
      </div>

      <div class="panel__body">
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Tag</th>
                <th>Volume</th>
                <th>Sentimento Médio</th>
                <th>Receita Perdida</th>
                <th>Priority Score</th>
              </tr>
            </thead>
            <tbody>
              <% @top_problems.each do |problem| %>
                <tr>
                  <td>
                    <%= link_to problem.tag, classification_path(problem.id) %>
                  </td>
                  <td><%= problem.volume %></td>
                  <td><%= problem.avg_sentiment %></td>
                  <td>R$ <%= number_with_delimiter(problem.revenue_lost.to_i) %></td>
                  <td><strong><%= problem.priority_score %></strong></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  <% end %>

  <!-- Chart -->
  <section class="panel">
    <div class="panel__header">
      <h2 class="panel__title">Conversation Trend</h2>
      <p class="panel__subtitle">
        From <%= @start_date.strftime('%d %b %Y') %>
        to <%= @end_date.strftime('%d %b %Y') %>
      </p>
    </div>

    <div
      class="panel__body"
      data-controller="weekly-conversation-chart"
      data-weekly-conversation-chart-series-value="<%= @chart_data.to_json %>"
    >
      <canvas data-weekly-conversation-chart-target="canvas"></canvas>
    </div>
  </section>
</div>

<script>
document.addEventListener("turbo:load", function () {
  flatpickr("#dateRange", {
    mode: "range",
    showMonths: 2,
    dateFormat: "Y-m-d",
    altInput: true,
    altFormat: "d M",
    locale: {
      ...flatpickr.l10ns.pt,
      rangeSeparator: " - "
    },
    closeOnSelect: false,
    disableMobile: true,
    defaultDate: [
      "<%= @start_date %>",
      "<%= @end_date %>"
    ],
    onChange(selectedDates) {
      if (selectedDates.length !== 2) return;
      const start = selectedDates[0];
      const end   = selectedDates[1];
      document.getElementById("startDate").value = start.toISOString().slice(0, 10);
      document.getElementById("endDate").value = end.toISOString().slice(0, 10);
      applyDateRange(start, end, "custom");
    }
  });
});
</script>
